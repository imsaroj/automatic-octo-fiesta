{
  "name": "@iamsaroj/smart-ui",
  "version": "4.2.0",
  "description": "Config-driven React 19 component library: Smart* shadcn/ui wrappers, declarative form/search engines, AG Grid data grids, tree, transfer list, calendar, and a Lexical rich-text editor.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imsaroj/automatic-octo-fiesta.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "react",
    "components",
    "shadcn",
    "tailwindcss",
    "ag-grid",
    "forms",
    "lexical"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/styles/globals.css",
    "src/styles/fonts.css",
    "src/styles/layout.css",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:lib": "tsc -p tsconfig.lib.json"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@fontsource/nanum-gothic": "^5.2.7",
    "@lexical/code": "^0.46.0",
    "@lexical/history": "^0.46.0",
    "@lexical/html": "^0.46.0",
    "@lexical/link": "^0.46.0",
    "@lexical/list": "^0.46.0",
    "@lexical/markdown": "^0.46.0",
    "@lexical/react": "^0.46.0",
    "@lexical/rich-text": "^0.46.0",
    "@lexical/selection": "^0.46.0",
    "@lexical/table": "^0.46.0",
    "@lexical/utils": "^0.46.0",
    "@sun-typeface/suit": "^2.0.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/react-table": "^8.21.3",
    "ag-grid-community": "^35.3.1",
    "ag-grid-react": "^35.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lexical": "^0.46.0",
    "lucide-react": "^1.22.0",
    "next-themes": "^0.4.6",
    "pretendard": "^1.3.9",
    "react-day-picker": "^10.0.1",
    "recharts": "^3.9.2",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^10",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4",
    "typescript": "~6",
    "typescript-eslint": "^8",
    "vitest": "^4.1.9"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./smart-components": "./src/smart-components/index.ts",
    "./smart-components/page": "./src/smart-components/page/index.ts",
    "./smart-components/buttons": "./src/smart-components/buttons/index.ts",
    "./smart-components/*": "./src/smart-components/*.tsx",
    "./layout": "./src/layout/index.ts",
    "./form": "./src/form/index.ts",
    "./search": "./src/search/index.ts",
    "./data-grid": "./src/data-grid/index.ts",
    "./tree": "./src/tree/index.ts",
    "./transfer-list": "./src/transfer-list/index.ts",
    "./calendar": "./src/calendar/index.ts",
    "./text-editor": "./src/text-editor/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./globals.css": "./src/styles/globals.css",
      "./lib/*": {
        "types": "./dist/lib/*.d.ts",
        "default": "./dist/lib/*.js"
      },
      "./components/*": {
        "types": "./dist/components/*.d.ts",
        "default": "./dist/components/*.js"
      },
      "./hooks/*": {
        "types": "./dist/hooks/*.d.ts",
        "default": "./dist/hooks/*.js"
      },
      "./smart-components": {
        "types": "./dist/smart-components/index.d.ts",
        "default": "./dist/smart-components/index.js"
      },
      "./smart-components/page": {
        "types": "./dist/smart-components/page/index.d.ts",
        "default": "./dist/smart-components/page/index.js"
      },
      "./smart-components/buttons": {
        "types": "./dist/smart-components/buttons/index.d.ts",
        "default": "./dist/smart-components/buttons/index.js"
      },
      "./smart-components/*": {
        "types": "./dist/smart-components/*.d.ts",
        "default": "./dist/smart-components/*.js"
      },
      "./layout": {
        "types": "./dist/layout/index.d.ts",
        "default": "./dist/layout/index.js"
      },
      "./form": {
        "types": "./dist/form/index.d.ts",
        "default": "./dist/form/index.js"
      },
      "./search": {
        "types": "./dist/search/index.d.ts",
        "default": "./dist/search/index.js"
      },
      "./data-grid": {
        "types": "./dist/data-grid/index.d.ts",
        "default": "./dist/data-grid/index.js"
      },
      "./tree": {
        "types": "./dist/tree/index.d.ts",
        "default": "./dist/tree/index.js"
      },
      "./transfer-list": {
        "types": "./dist/transfer-list/index.d.ts",
        "default": "./dist/transfer-list/index.js"
      },
      "./calendar": {
        "types": "./dist/calendar/index.d.ts",
        "default": "./dist/calendar/index.js"
      },
      "./text-editor": {
        "types": "./dist/text-editor/index.d.ts",
        "default": "./dist/text-editor/index.js"
      }
    }
  }
}
